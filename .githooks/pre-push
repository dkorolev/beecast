#!/bin/sh
# The full gate runs when code is about to leave the machine; committing stays free.
# Enable once per clone: git config core.hooksPath .githooks
set -e
cd "$(git rev-parse --show-toplevel)"
cargo fmt --check
cargo clippy --workspace --all-targets -- -D warnings
cargo test --workspace
cargo test --workspace --release
python3 -m unittest discover -s seecast/tests
# Packaging (the dry run of publishing) must be warning-free: a warning here means the
# published crates would silently differ from the repo's intent. Cargo's transient
# "spurious network error" retry warnings from the index fetch are not packaging
# warnings — filter them out before the gate, same as CI.
pkg_out="$(cargo package --workspace --allow-dirty 2>&1)" || { printf '%s\n' "$pkg_out"; exit 1; }
real="$(printf '%s\n' "$pkg_out" | grep 'warning:' | grep -v 'spurious network error' || true)"
if [ -n "$real" ]; then printf '%s\n' "$pkg_out"; echo "cargo package must be warning-free"; exit 1; fi
